[mysqld]
# Percona Server 8.4 with MyRocks — CSD MVCC filter (QEMU VM variant)
# Binary: /usr/local/percona-csd/bin/mysqld
# Used by db-eval profiling scripts running inside the VM.
user = root
port = 3306
socket = /tmp/mysql_csd.sock
pid-file = /tmp/mysql_csd.pid
datadir = /root/mysql-data
basedir = /usr/local/percona-csd

# Storage Engine
default-storage-engine = ROCKSDB

# Load RocksDB Plugin
plugin-load-add = ha_rocksdb.so

# Transaction and Collation Settings (recommended for MyRocks)
transaction-isolation = READ-COMMITTED
character-set-server = latin1
collation-server = latin1_bin

# CEMU MVCC filter pushdown — must match persisted CemuTableFactory in existing data
# The profiling script controls this per-run via SET GLOBAL
rocksdb_cemu_enabled = ON
rocksdb_cache_index_and_filter_blocks = false

# Match server-side percona-myrocks config for fair comparison.
# target_file_size_base and write_buffer_size are per-CF options — they must be
# set inside rocksdb_default_cf_options, not as standalone mysqld variables.
# 32MB cap ensures all SSTs stay within the FDMFS pre-allocated file limit so
# the CSD path covers every SST; must be in effect before data prep runs.
rocksdb_default_cf_options = compression=kNoCompression;block_based_table_factory={filter_policy=bloomfilter:10:false;whole_key_filtering=1};target_file_size_base=33554432;write_buffer_size=33554432
rocksdb_allow_concurrent_memtable_write = ON
rocksdb_max_open_files = -1

# Enable perf context counters (level 1 = count only, minimal overhead)
rocksdb_perf_context_level = 1

# Binary log (ROW format for realistic production settings)
binlog_format = ROW

# Disable query logging for benchmarking
slow_query_log = 0
general_log = 0

# Disable Performance Schema
performance_schema = OFF

# Enable LOAD DATA LOCAL INFILE for bulk loading
local_infile = 1

[client]
socket = /tmp/mysql_csd.sock
